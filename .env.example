# ---------------------------------------------------------------------------
# Ajaia Docs — environment template.
# Copy this file to `.env.local` and fill in the values, then restart `pnpm dev`.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# New Supabase API keys (Project Settings -> API Keys).
# We deliberately use the NEW key system, not the legacy anon / service_role keys.

# Publishable key (safe to expose to the browser): starts with `sb_publishable_...`
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (server-only, never sent to the browser): starts with `sb_secret_...`
SUPABASE_SECRET_KEY=

# Secret used to sign the simulated-auth session cookie (any long random string).
# Generate one with: openssl rand -base64 32
SESSION_SECRET=
